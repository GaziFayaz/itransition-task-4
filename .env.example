# Copy this to .env and fill in your actual values

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:80

# Database Connection String
# Replace with your actual Azure SQL connection string
ConnectionStrings__DefaultConnection=Server=tcp:YOUR-SERVER.database.windows.net,1433;Initial Catalog=YOUR-DATABASE;Persist Security Info=False;User ID=YOUR-USERNAME;Password=YOUR-PASSWORD;Encrypt=True;Connection Timeout=30;

# Resend API Configuration
# Get your API key from https://resend.com/api-keys
Resend__ApiKey=re_YOUR_API_KEY_HERE

# Email Configuration (optional overrides)
Email__FromEmail=task4@resend.gazifayazahmed.site
Email__FromName=Task 4 User

# Logging Configuration (optional)
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
